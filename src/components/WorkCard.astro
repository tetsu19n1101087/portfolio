---
const { work } = Astro.props;
import styles from './WorkCard.module.css';

const id = work.id ?? work.contentId ?? work.slug ?? '';
const imageUrl = work.images[0]?.url ?? work.thumbnail?.url ?? '';
---

<a class={styles.card} href={id ? `/works/${id}` : '#'}>
  <div class={styles.imageWrap}>
    {imageUrl ? <img src={imageUrl} alt={work.title ?? 'work image'} loading="lazy" /> : <div />}
  </div>
  <div class={styles.body}>
    <h3 class={styles.title}>{work.title}</h3>
    {work.date ? <p class={styles.meta}>{work.date}</p> : null}
  </div>
</a>
