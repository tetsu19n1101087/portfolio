---
export const prerender = false;

import { getWorkById } from '@/lib/works';
import BaseLayout from '@/layouts/BaseLayout.astro';
import './index.css';

const { id } = Astro.params;
const work = await getWorkById(id!);

if (!work) return Astro.redirect('/404');

const heroImage = work.image?.url ?? work.images[0]?.url;
---

<BaseLayout title={`${work.title} | My Portfolio`}>
  <article class='work-detail'>
    <header class='work-detail_header'>
      <a href='/works' class='work-detail_back'>← Works</a>
      <p class='work-detail_kicker'>works</p>
      <h1 class='work-detail_title'>{work.title}</h1>
      <div class='work-detail_meta'>
        <time class='work-detail_date'>{work.date}</time>
        {
          work.tags.length > 0 && (
            <ul class='work-detail_tags' aria-label='タグ'>
              {work.tags.map((tag) => (
                <li class='work-detail_tag'>{tag.name}</li>
              ))}
            </ul>
          )
        }
      </div>
    </header>

    {
      heroImage && (
        <div class='work-detail_hero'>
          <img src={heroImage} alt={work.title} />
        </div>
      )
    }

    <div class='work-detail_body'>
      <p class='work-detail_description'>{work.description}</p>
      <div class='work-detail_text' set:html={work.text} />
    </div>

    {
      (work.demoLink || work.codeLink) && (
        <footer class='work-detail_links'>
          {work.demoLink && (
            <a href={work.demoLink} target='_blank' rel='noopener noreferrer' class='work-detail_link'>
              Demo →
            </a>
          )}
          {work.codeLink && (
            <a href={work.codeLink} target='_blank' rel='noopener noreferrer' class='work-detail_link'>
              Code →
            </a>
          )}
        </footer>
      )
    }
  </article>
</BaseLayout>
